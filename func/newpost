# Create post automatically.
# Usage : newpost "My Title"
newpost() {

  # read latest number of posts
  n=$(ls content/posts \
      | sed -E 's/^([0-9]+)\.md$/\1/' \
      | grep -E '^[0-9]+$' \
      | sort -n \
      | tail -1)
  i=$((n+1))
  hugo new posts/${i}.md --kind posts

  sed -i "s|^title *=.*|title = \"$*\"|" \
    content/posts/${i}.md

  echo "생성된 파일: content/posts/${i}.md"
}